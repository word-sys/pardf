#!/usr/bin/make -f

PKGDDIR=debian/fospx-pdf-editor
INSTALL_DIR=$(PKGDDIR)/opt/fospx-pdf-editor
BIN_DIR=$(PKGDDIR)/usr/bin

ICON_NAME=f-pv1
ICON_SOURCE_PATH=fospx_pdf_editor/img/f-pv1.svg
ICON_SIZE_DIR=scalable
ICON_INSTALL_DIR=$(PKGDDIR)/usr/share/icons/hicolor/$(ICON_SIZE_DIR)/apps

%:
	dh $@

override_dh_auto_build:
	# PyMuPDF and numpy are installed at package-install time via debian/postinst
	# using a per-host Python venv, so no build-time pip vendoring is needed.

override_dh_install:
	install -d $(INSTALL_DIR)
	cp -r fospx_pdf_editor $(INSTALL_DIR)/
	install -m 644 run_pardf.py $(INSTALL_DIR)/

	install -d $(BIN_DIR)
	printf '#!/bin/sh\nexec /opt/fospx-pdf-editor/.venv/bin/python3 /opt/fospx-pdf-editor/run_pardf.py "$$@"\n' \
		> $(BIN_DIR)/fospx-pdf-editor
	chmod 755 $(BIN_DIR)/fospx-pdf-editor

	install -d $(PKGDDIR)/usr/share/applications
	install -m 644 debian/fospx-pdf-editor.desktop $(PKGDDIR)/usr/share/applications/

	install -d $(ICON_INSTALL_DIR)
	install -m 644 $(ICON_SOURCE_PATH) $(ICON_INSTALL_DIR)/$(ICON_NAME).svg

override_dh_strip:

override_dh_shlibdeps:

override_dh_auto_clean:
	dh_auto_clean
	rm -rf __pycache__ fospx_pdf_editor/__pycache__
